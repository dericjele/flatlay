# PhotoRoom API Key
# Get yours at: https://www.photoroom.com/api
# Free tier: 30 images/month. Paid from ~$0.05/image
PHOTOROOM_API_KEY=xxxxx

# Supabase (reused project — find these in Supabase dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
NODE_ENV=development

# Daily BG removal cap per verified user (default 10, set lower for testing)
NEXT_PUBLIC_DAILY_BG_LIMIT=10

